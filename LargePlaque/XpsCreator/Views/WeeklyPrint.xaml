<UserControl x:Class="XpsCreator.Views.WeeklyPrint"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator.Views"
             xmlns:vm="clr-namespace:XpsCreator.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="800" FontSize="16">
    <UserControl.DataContext>
        <vm:WeeklyPrintViewModel />
    </UserControl.DataContext>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <DataGrid Grid.Row="0" ItemsSource="{Binding PrintItems}" AutoGenerateColumns="False" Margin="10">
            <DataGrid.Columns>
                <DataGridTextColumn Header="{DynamicResource ContactName}" Binding="{Binding ContactName}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource ContactCode}" Binding="{Binding ContactCode}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource Summary}" Binding="{Binding Summary}" Width="2*"/>
                <DataGridTemplateColumn Header="{DynamicResource Action}" Width="Auto">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Content="{DynamicResource Unprint}" 
                                    Command="{Binding DataContext.ActionCommand, RelativeSource={RelativeSource AncestorType={x:Type UserControl}}}"
                                    CommandParameter="{Binding}" 
                                    Margin="2"/>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>

        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="10">
            <Button Content="{DynamicResource Refresh}" Command="{Binding LoadItemsCommand}" Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="{DynamicResource GenerateWeeklyXps}" Command="{Binding GenerateXpsCommand}" Margin="0,0,10,0" Padding="10,5"/>
            <Button Content="{DynamicResource ClearPrint}" Command="{Binding ClearPrintCommand}" Padding="10,5"/>
        </StackPanel>
    </Grid>
</UserControl>
