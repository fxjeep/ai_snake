<UserControl x:Class="XpsCreator.Views.DetailEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="500">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#f0f0f0" Padding="10" Margin="0,0,0,10" CornerRadius="4">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="{DynamicResource EditingDetails}" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentContact.Name}" FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding CurrentContact.Code, StringFormat=' ({0})'}" Foreground="Gray" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>
        
        <TabControl Grid.Row="1">
            <TabItem Header="{DynamicResource TabLive}">
                <DataGrid ItemsSource="{Binding LiveRecords}" AutoGenerateColumns="True" Margin="5"/>
            </TabItem>
            <TabItem Header="{DynamicResource TabDead}">
                <DataGrid ItemsSource="{Binding DeadRecords}" AutoGenerateColumns="True" Margin="5"/>
            </TabItem>
            <TabItem Header="{DynamicResource TabAncestor}">
                <DataGrid ItemsSource="{Binding AncestorRecords}" AutoGenerateColumns="True" Margin="5"/>
            </TabItem>
            <TabItem Header="{DynamicResource TabProperty}">
                <DataGrid ItemsSource="{Binding PropertyRecords}" AutoGenerateColumns="True" Margin="5"/>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
