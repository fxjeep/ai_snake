<UserControl x:Class="XpsCreator.Views.DetailEditor"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator.Views"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="500">
    <UserControl.Resources>
        <Style x:Key="IsPrintIconStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Segoe MDL2 Assets"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsPrint}" Value="True">
                    <Setter Property="Text" Value="&#xE749;"/> <!-- Printer icon -->
                    <Setter Property="Foreground" Value="Green"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding IsPrint}" Value="False">
                    <Setter Property="Text" Value=""/> <!-- Empty -->
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <Border Grid.Row="0" Background="#f0f0f0" Padding="10" Margin="0,0,0,10" CornerRadius="4">
            <DockPanel>
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
                    <TextBlock Text="{DynamicResource EditingDetails}" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentContact.Name}" FontWeight="Bold" Margin="5,0,0,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding CurrentContact.Code, StringFormat=' ({0})'}" Foreground="Gray" VerticalAlignment="Center"/>
                </StackPanel>
                
                <StackPanel Orientation="Horizontal" DockPanel.Dock="Right" HorizontalAlignment="Right">
                    <TextBox Width="150" Margin="0,0,10,0" VerticalContentAlignment="Center"
                             Text="{Binding FilterText, UpdateSourceTrigger=PropertyChanged}"
                             Tag="Filter..."/>
                    
                    <Button Click="PrintButton_Click" Margin="0,0,5,0" ToolTip="Print Selected">
                        <TextBlock Text="&#xE749;" FontFamily="Segoe MDL2 Assets" Margin="5"/>
                    </Button>
                    <Button Click="NotPrintButton_Click" Margin="0,0,5,0" ToolTip="Not Print Selected">
                        <TextBlock Text="&#xE8D8;" FontFamily="Segoe MDL2 Assets" Margin="5"/>
                    </Button>
                    <Button Click="DeleteButton_Click" ToolTip="Delete Selected">
                        <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" Margin="5"/>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
        
        <TabControl Grid.Row="1" x:Name="DetailTabControl">
            <TabItem Header="{DynamicResource TabLive}">
                <DataGrid x:Name="LiveGrid" ItemsSource="{Binding LiveView}" AutoGenerateColumns="False" Margin="5" InitializingNewItem="DataGrid_InitializingNewItem" RowEditEnding="DataGrid_RowEditEnding">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource IsPrint}" Width="SizeToHeader">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource IsPrintIconStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Name}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource LastPrint}" Binding="{Binding LastPrint}" Width="SizeToHeader" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{DynamicResource TabDead}">
                <DataGrid x:Name="DeadGrid" ItemsSource="{Binding DeadView}" AutoGenerateColumns="False" Margin="5" InitializingNewItem="DataGrid_InitializingNewItem" RowEditEnding="DataGrid_RowEditEnding">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource IsPrint}" Width="SizeToHeader">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource IsPrintIconStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource DeadName}" Binding="{Binding DeadName}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource LiveName}" Binding="{Binding LiveName}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource Relation}" Binding="{Binding Relation}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource LastPrint}" Binding="{Binding LastPrint}" Width="SizeToHeader" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{DynamicResource TabAncestor}">
                <DataGrid x:Name="AncestorGrid" ItemsSource="{Binding AncestorView}" AutoGenerateColumns="False" Margin="5" InitializingNewItem="DataGrid_InitializingNewItem" RowEditEnding="DataGrid_RowEditEnding">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource IsPrint}" Width="SizeToHeader">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource IsPrintIconStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource Surname}" Binding="{Binding Surname}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource Name}" Binding="{Binding Name}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource LastPrint}" Binding="{Binding LastPrint}" Width="SizeToHeader" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
            <TabItem Header="{DynamicResource TabProperty}">
                <DataGrid x:Name="PropertyGrid" ItemsSource="{Binding PropertyView}" AutoGenerateColumns="False" Margin="5" InitializingNewItem="DataGrid_InitializingNewItem" RowEditEnding="DataGrid_RowEditEnding">
                    <DataGrid.Columns>
                        <DataGridTemplateColumn Header="{DynamicResource IsPrint}" Width="SizeToHeader">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <TextBlock Style="{StaticResource IsPrintIconStyle}"/>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="{DynamicResource LiveName}" Binding="{Binding LiveName}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource Address}" Binding="{Binding Address}" Width="SizeToHeader"/>
                        <DataGridTextColumn Header="{DynamicResource LastPrint}" Binding="{Binding LastPrint}" Width="SizeToHeader" IsReadOnly="True"/>
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</UserControl>
