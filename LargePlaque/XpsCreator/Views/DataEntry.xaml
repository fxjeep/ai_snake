<UserControl x:Class="XpsCreator.Views.DataEntry"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator.Views"
             xmlns:vm="clr-namespace:XpsCreator.ViewModels"
             mc:Ignorable="d" 
             d:DesignHeight="600" d:DesignWidth="1000">
    <UserControl.DataContext>
        <vm:DataEntryViewModel />
    </UserControl.DataContext>
    
    <UserControl.Resources>
        <Style x:Key="VisibilityBySelectionStyle" TargetType="FrameworkElement">
            <Setter Property="Visibility" Value="Visible"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding DataContext.ContactSearch.SelectedContact, RelativeSource={RelativeSource AncestorType=UserControl}}" Value="{x:Null}">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="Auto"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        
        <!-- Left: Contact Search -->
        <local:ContactSearch DataContext="{Binding ContactSearch}"/>
        
        <!-- Splitter -->
        <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Center" VerticalAlignment="Stretch" Background="#e0e0e0"
                      Style="{StaticResource VisibilityBySelectionStyle}"/>
        
        <!-- Right: Detail Editor -->
        <local:DetailEditor Grid.Column="2" DataContext="{Binding DetailEditor}"
                            Style="{StaticResource VisibilityBySelectionStyle}"/>
    </Grid>
</UserControl>
