<UserControl x:Class="XpsCreator.Views.ContactSearch"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator.Views"
             xmlns:models="clr-namespace:PlaqueData.Models;assembly=PlaqueData"
             mc:Ignorable="d" 
             d:DesignHeight="450" d:DesignWidth="400">
    <UserControl.Resources>
        <local:IntToBooleanConverter x:Key="IntToBooleanConverter"/>
    </UserControl.Resources>
    
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        
        <!-- Search Bar -->
        <DockPanel Grid.Row="0" Margin="0,0,0,10">
            <Button Command="{Binding SearchCommand}" DockPanel.Dock="Right" Width="30" Height="30" Margin="5,0,0,0">
                <TextBlock Text="&#xE721;" FontFamily="Segoe MDL2 Assets" VerticalAlignment="Center" HorizontalAlignment="Center"/>
            </Button>
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" VerticalContentAlignment="Center" Height="30">
                <TextBox.InputBindings>
                    <KeyBinding Key="Enter" Command="{Binding SearchCommand}"/>
                </TextBox.InputBindings>
            </TextBox>
        </DockPanel>

        <!-- Tool Bar -->
        <ToolBarTray Grid.Row="1" Background="Transparent">
            <ToolBar Background="Transparent" ToolBarTray.IsLocked="True">
                <Button Command="{Binding AddContactCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" Margin="0,0,5,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{DynamicResource AddContact}" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </ToolBar>
        </ToolBarTray>
        
        <!-- Search Results -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding FilteredContacts}" SelectedItem="{Binding SelectedContact}" 
                  AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,10,0,0"
                  CellEditEnding="DataGrid_CellEditEnding">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="{DynamicResource IsPrint}" Binding="{Binding IsPrint, Converter={StaticResource IntToBooleanConverter}}"/>
                <DataGridTextColumn Header="{DynamicResource ContactName}" Binding="{Binding Name}" Width="*"/>
                <DataGridTextColumn Header="{DynamicResource ContactCode}" Binding="{Binding Code}" Width="80"/>
                <DataGridTextColumn Header="{DynamicResource LastPrintDate}" Binding="{Binding LastPrint}" Width="100" IsReadOnly="True"/>
                
                <DataGridTemplateColumn Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <Button Background="Transparent" BorderThickness="0" HorizontalAlignment="Center" VerticalAlignment="Center" Click="ActionButton_Click">
                                <TextBlock Text="&#xE712;" FontFamily="Segoe MDL2 Assets"/>
                                <Button.ContextMenu>
                                    <ContextMenu>
                                        <MenuItem Header="{DynamicResource Detail}" Command="{Binding DataContext.DetailCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        <MenuItem Header="{DynamicResource Delete}" Command="{Binding DataContext.DeleteContactCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                        <Separator/>
                                        <MenuItem Header="{DynamicResource Print}" Command="{Binding DataContext.TogglePrintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPrint}" Value="0">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource Unprint}" Command="{Binding DataContext.TogglePrintCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}">
                                            <MenuItem.Style>
                                                <Style TargetType="MenuItem">
                                                    <Setter Property="Visibility" Value="Collapsed"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsPrint}" Value="1">
                                                            <Setter Property="Visibility" Value="Visible"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </MenuItem.Style>
                                        </MenuItem>
                                        <MenuItem Header="{DynamicResource CreateList}" Command="{Binding DataContext.CreateListCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" CommandParameter="{Binding}"/>
                                    </ContextMenu>
                                </Button.ContextMenu>
                            </Button>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
