<Window x:Class="XpsCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XpsCreator"
        xmlns:views="clr-namespace:XpsCreator.Views"
        mc:Ignorable="d"
        Title="{DynamicResource Title}" Height="450" Width="800">
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="{DynamicResource Exit}" Click="Exit_Click"/>
                <Separator/>
                <RadioButton Content="EN" IsChecked="True" Style="{StaticResource {x:Type ToggleButton}}" Click="Language_Click" Tag="en"/>
                <RadioButton Content="CN" Style="{StaticResource {x:Type ToggleButton}}" Click="Language_Click" Tag="cn"/>
            </ToolBar>
        </ToolBarTray>
        <TabControl x:Name="MainTabControl">
            <TabItem Header="{DynamicResource TabPositionConfigure}">
                <local:PositionConfigure />
            </TabItem>
            <TabItem Header="{DynamicResource TabTextInput}">
                <local:TextInput />
            </TabItem>
            <TabItem Header="{DynamicResource TabPropertyFilePrint}">
                <local:Property />
            </TabItem>
            <TabItem Header="{DynamicResource TabWeeklyPlaqueData}">
                <views:DataEntry />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
