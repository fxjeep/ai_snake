<Window x:Class="XpsCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XpsCreator"
        mc:Ignorable="d"
        Title="A3 XPS Creator" Height="450" Width="800">
    <DockPanel>
        <ToolBarTray DockPanel.Dock="Top">
            <ToolBar>
                <Button Content="New"/>
                <Button Content="Open"/>
                <Button Content="Save"/>
                <Separator/>
                <Button Content="Exit"/>
            </ToolBar>
        </ToolBarTray>
        <TabControl x:Name="MainTabControl">
            <TabItem Header="Text Input">
                <Grid Background="#FFE5E5E5"/>
            </TabItem>
            <TabItem Header="Position Configure">
                <local:PositionConfigure />
            </TabItem>
            <TabItem Header="Generate &amp; Print">
                <local:GenerateXPS />
            </TabItem>
        </TabControl>
    </DockPanel>
</Window>
