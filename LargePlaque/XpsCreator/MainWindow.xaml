<Window x:Class="XpsCreator.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:XpsCreator"
        mc:Ignorable="d"
        Title="A3 XPS Creator" Height="450" Width="800">
    <Grid>
        <StackPanel Orientation="Vertical" HorizontalAlignment="Center" VerticalAlignment="Center">
            <ComboBox x:Name="TypeComboBox" Width="150" Height="40" FontSize="16" VerticalContentAlignment="Center" Margin="0,0,20,0" SelectedIndex="0">
                <ComboBoxItem Content="长生"/>
                <ComboBoxItem Content="消灾"/>
                <ComboBoxItem Content="往生"/>
                <ComboBoxItem Content="祖先"/>
            </ComboBox>
            <CheckBox x:Name="PrintBorderCheckBox" Content="Print border" Margin="0,0,20,10" VerticalAlignment="Center" FontSize="16"/>
            <CheckBox x:Name="PrintRedStampCheckBox" Content="Print Red Stamp" Margin="0,0,20,10" VerticalAlignment="Center" FontSize="16"/>
            <Button Content="Open File" Width="150" Height="40" FontSize="16" Click="OpenFileButton_Click"/>
        </StackPanel>
    </Grid>
</Window>
