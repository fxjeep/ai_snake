<UserControl x:Class="XpsCreator.PositionConfigure"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator"
             mc:Ignorable="d" 
             d:DesignHeight="800" d:DesignWidth="1200">
    <Grid Background="White">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*"/>
            <ColumnDefinition Width="1*"/>
        </Grid.ColumnDefinitions>

        <!-- Designer Column -->
        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto">
            <Viewbox Stretch="Uniform">
                <local:DesignCanvas x:Name="Designer" Margin="20"/>
            </Viewbox>
        </ScrollViewer>

        <!-- Configuration Column -->
        <ScrollViewer Grid.Column="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Margin="10" Orientation="Vertical">
            <GroupBox Header="View Settings">
                <StackPanel Margin="5">
                    <DockPanel>
                        <Button Content="-" Click="ZoomOut_Click" Width="30" DockPanel.Dock="Left"/>
                        <Button Content="+" Click="ZoomIn_Click" Width="30" DockPanel.Dock="Right"/>
                        <Slider x:Name="ZoomSlider" Minimum="0.1" Maximum="3.0" Value="1.0" ValueChanged="ZoomSlider_ValueChanged"/>
                    </DockPanel>
                    <TextBlock Text="{Binding Value, ElementName=ZoomSlider, StringFormat=Zoom: {0:P0}}" HorizontalAlignment="Center"/>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="General Settings">
                <StackPanel Margin="5">
                    <Label Content="Select Type:"/>
                    <ComboBox x:Name="TypeComboBox" SelectionChanged="TypeComboBox_SelectionChanged">
                        <ComboBoxItem Content="长生"/>
                        <ComboBoxItem Content="冤亲"/>
                        <ComboBoxItem Content="往生"/>
                        <ComboBoxItem Content="祖先"/>
                    </ComboBox>
                </StackPanel>
            </GroupBox>

            <GroupBox Header="Background Image">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Content="Select Background" Click="SelectBackground_Click" VerticalAlignment="Stretch"/>
                    <StackPanel Grid.Column="1">
                        <Label Content="Width (cm):" Padding="2"/>
                        <TextBox x:Name="BgWidthTxt" Text="29.7" TextChanged="Bg_Changed"/>
                        <Label Content="Height (cm):" Padding="2"/>
                        <TextBox x:Name="BgHeightTxt" Text="42.0" TextChanged="Bg_Changed"/>
                    </StackPanel>
                </Grid>
            </GroupBox>

            <GroupBox Header="Stamp Image">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Button Content="Select Stamp" Click="SelectStamp_Click" Grid.ColumnSpan="2" Grid.Row="0"/>
                    <Label Content="Left (cm):" Padding="2" Grid.Row="1" Grid.Column="0"/>
                    <Label Content="Width (cm):" Padding="2" Grid.Row="1" Grid.Column="1"/>
                    <TextBox x:Name="StampLeftTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="2" Grid.Column="0"/>
                    <TextBox x:Name="StampWidthTxt" Text="6.0" TextChanged="Stamp_Changed" Grid.Row="2" Grid.Column="1"/>
                    <Label Content="Top (cm):" Padding="2" Grid.Row="3" Grid.Column="0"/>
                    <Label Content="Height (cm):" Padding="2" Grid.Row="3" Grid.Column="1"/>
                    <TextBox x:Name="StampTopTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="4" Grid.Column="0"/>
                    <TextBox x:Name="StampHeightTxt" Text="6.0" TextChanged="Stamp_Changed" Grid.Row="4" Grid.Column="1"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Main Box">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Left (cm):" Padding="2" Grid.Row="0" Grid.Column="0"/>
                    <Label Content="Width (cm):" Padding="2" Grid.Row="0" Grid.Column="1"/>
                    <TextBox x:Name="MainLeftTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="1" Grid.Column="0"/>
                    <TextBox x:Name="MainWidthTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="1" Grid.Column="1"/>
                    <Label Content="Top (cm):" Padding="2" Grid.Row="2" Grid.Column="0"/>
                    <Label Content="Height (cm):" Padding="2" Grid.Row="2" Grid.Column="1"/>
                    <TextBox x:Name="MainTopTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="3" Grid.Column="0"/>
                    <TextBox x:Name="MainHeightTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="3" Grid.Column="1"/>
                </Grid>
            </GroupBox>

            <GroupBox x:Name="SideBoxGroup" Header="Side Box">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Left (cm):" Padding="2" Grid.Row="0" Grid.Column="0"/>
                    <Label Content="Width (cm):" Padding="2" Grid.Row="0" Grid.Column="1"/>
                    <TextBox x:Name="SideLeftTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="1" Grid.Column="0"/>
                    <TextBox x:Name="SideWidthTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="1" Grid.Column="1"/>
                    <Label Content="Top (cm):" Padding="2" Grid.Row="2" Grid.Column="0"/>
                    <Label Content="Height (cm):" Padding="2" Grid.Row="2" Grid.Column="1"/>
                    <TextBox x:Name="SideTopTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="3" Grid.Column="0"/>
                    <TextBox x:Name="SideHeightTxt" Text="0" IsReadOnly="True" Background="#F0F0F0" Grid.Row="3" Grid.Column="1"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Font Sizes">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Large" Grid.Column="0"/>
                    <Label Content="Medium" Grid.Column="1"/>
                    <Label Content="Small" Grid.Column="2"/>
                    <TextBox x:Name="FontSizeLargeTxt" Grid.Row="1" Grid.Column="0" Text="47"/>
                    <TextBox x:Name="FontSizeMediumTxt" Grid.Row="1" Grid.Column="1" Text="37"/>
                    <TextBox x:Name="FontSizeSmallTxt" Grid.Row="1" Grid.Column="2" Text="30"/>
                </Grid>
            </GroupBox>

            <GroupBox Header="Line Thresholds">
                <Grid Margin="5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Label Content="Large Lines" Grid.Column="0"/>
                    <Label Content="Medium Lines" Grid.Column="1"/>
                    <TextBox x:Name="LargeLinesTxt" Grid.Row="1" Grid.Column="0" Text="7"/>
                    <TextBox x:Name="MediumLinesTxt" Grid.Row="1" Grid.Column="1" Text="10"/>
                </Grid>
            </GroupBox>

            <Button Content="Save Configuration" Click="Save_Click" Height="40" Margin="0,20,0,0" FontWeight="Bold"/>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</UserControl>
