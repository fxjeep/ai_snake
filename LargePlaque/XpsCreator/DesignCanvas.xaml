<UserControl x:Class="XpsCreator.DesignCanvas"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:XpsCreator"
             mc:Ignorable="d" 
             d:DesignHeight="1587" d:DesignWidth="1122" Width="1122.5" Height="1587.4">
    <!-- A3 297 x 420 mm = 1122.5 x 1587.4 pixels at 96 DPI -->
    <UserControl.LayoutTransform>
        <TransformGroup>
            <ScaleTransform x:Name="CanvasScaleTransform" ScaleX="1" ScaleY="1"/>
        </TransformGroup>
    </UserControl.LayoutTransform>
    <Grid>
        <Border BorderBrush="Black" BorderThickness="1" Background="White">
            <Canvas x:Name="MainCanvas">
                <!-- Background Image -->
                <Image x:Name="BackgroundImage" Stretch="Fill" Opacity="0.5" Panel.ZIndex="0"/>
                
                <!-- Stamp Image -->
                <ContentControl x:Name="StampControl" Canvas.Left="0" Canvas.Top="0" Width="100" Height="100" Panel.ZIndex="10" Visibility="Collapsed">
                    <Grid>
                        <Image x:Name="StampImage" Stretch="UniformToFill" Source="stamp.png"/>
                        <Border x:Name="StampBorder" BorderBrush="Red" BorderThickness="1" Background="Transparent" MouseLeftButtonDown="Element_MouseLeftButtonDown"/>
                    </Grid>
                </ContentControl>

                <!-- Text Box 1 (Main) -->
                <ContentControl x:Name="MainBoxControl" Canvas.Left="0" Canvas.Top="0" Width="200" Height="300" Panel.ZIndex="11">
                    <Grid>
                        <Border x:Name="MainBoxBorder" BorderBrush="Blue" BorderThickness="2" Background="#220000FF" MouseLeftButtonDown="Element_MouseLeftButtonDown">
                            <Canvas x:Name="MainBoxCanvas"/>
                        </Border>
                    </Grid>
                </ContentControl>

                <!-- Text Box 2 (Side) -->
                <ContentControl x:Name="SideBoxControl" Canvas.Left="0" Canvas.Top="0" Width="100" Height="200" Panel.ZIndex="12">
                    <Grid>
                        <Border x:Name="SideBoxBorder" BorderBrush="Green" BorderThickness="2" Background="#2200FF00" MouseLeftButtonDown="Element_MouseLeftButtonDown">
                            <Canvas x:Name="SideBoxCanvas"/>
                        </Border>
                    </Grid>
                </ContentControl>

                <!-- Resize Handles (Shared Adorner-like UI) -->
                <Canvas x:Name="AdornerCanvas" Panel.ZIndex="100" IsHitTestVisible="True" Visibility="Collapsed">
                    <Thumb x:Name="ResizeThumb" Width="8" Height="8" Background="White" BorderBrush="Black" BorderThickness="1" DragDelta="ResizeThumb_DragDelta" MouseEnter="ResizeThumb_MouseEnter" MouseLeave="ResizeThumb_MouseLeave"/>
                </Canvas>
            </Canvas>
        </Border>
    </Grid>
</UserControl>
